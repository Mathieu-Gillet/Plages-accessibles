# =============================================================
# PLAGES ACCESSIBLES — Variables d'environnement
# Copiez ce fichier en .env.local et remplissez les valeurs
# =============================================================

# ── Base de données PostgreSQL (obligatoire) ─────────────────
# Format : postgresql://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL="postgresql://postgres:password@localhost:5432/plages_accessibles"

# ── Google Maps (optionnel) ───────────────────────────────────
# Pour intégrer Google Maps en plus d'OpenStreetMap
# https://console.cloud.google.com/
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""

# ── URL publique du site ──────────────────────────────────────
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ── Modération des avis (optionnel) ──────────────────────────
# Clé secrète pour les routes admin
ADMIN_SECRET_KEY=""
